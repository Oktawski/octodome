{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to API Service (Docker)",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "/app/api",
            "port": 2345,
            "host": "127.0.0.1",
            "showLog": true,
            "substitutePath": [
                {
                    "from": "${workspaceFolder}/api",
                    "to": "/app/api"
                }
            ]
        },
        {
            "name": "Attach to Event Broker (Docker)",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "/app/event_broker",
            "port": 2346,
            "host": "127.0.0.1",
            "showLog": true,
            "substitutePath": [
                {
                    "from": "${workspaceFolder}/event_broker",
                    "to": "/app/event_broker"
                }
            ]
        },
        {
            "name": "Run Send Email Service",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/send_email_service",
            "env": {
                "EVENT_BROKER_URL": "http://localhost:8081",
                "SERVICE_URL": "http://localhost:8082",
                "PORT": "8082"
            }
        },
        {
            "name": "Attach to Send Email Service (Docker)",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "/app/send_email_service",
            "port": 2347,
            "host": "127.0.0.1",
            "showLog": true,
            "substitutePath": [
                {
                    "from": "${workspaceFolder}/send_email_service",
                    "to": "/app/send_email_service"
                }
            ]
        }
    ]
}